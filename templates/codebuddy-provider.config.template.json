{
  "version": 1,
  "daemon": {
    "listen": "127.0.0.1:6767",
    "cors": {
      "allowedOrigins": ["https://app.paseo.sh"]
    },
    "relay": {
      "enabled": true
    }
  },
  "app": {
    "baseUrl": "https://app.paseo.sh"
  },
  "agents": {
    "providers": {
      "codebuddy": {
        "extends": "acp",
        "label": "CodeBuddy",
        "description": "CodeBuddy Code CLI provider",
        "command": ["/opt/homebrew/bin/codebuddy", "--acp"]
      }
    }
  }
}
